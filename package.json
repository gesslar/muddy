{
  "name": "@gesslar/muddy",
  "description": "The red-headed stepchild of muddler.",
  "author": {
    "name": "gesslar",
    "url": "https://gesslar.dev"
  },
  "version": "1.4.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/muddy.git"
  },
  "bin": "./src/cli.js",
  "type": "module",
  "files": [
    "LICENSE.txt",
    "src/**/*.js"
  ],
  "keywords": [
    "mud",
    "muddy",
    "muddler",
    "demuddler",
    "mudlet",
    "lua",
    "para",
    "bailar",
    "la",
    "bamba"
  ],
  "license": "0BSD",
  "engines": {
    "node": ">=v24.11.0"
  },
  "icon": "mud-128.png",
  "homepage": "https://github.com/gesslar/muddy",
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "types": "tsc -p tsconfig.types.json",
    "build": "mkdir -pv ./dist && npm pack --pack-destination ./dist/",
    "update": "npx npm-check-updates -u && npm install",
    "submit": "npm publish --access public --//registry.npmjs.org/:_authToken=\"${NPM_ACCESS_TOKEN}\"",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:unit": "node --test test/unit/**/*.test.js",
    "muddy": "node src/cli.js work/ThresholdUI -n",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@gesslar/actioneer": "^3.0.1",
    "@gesslar/colours": "^1.0.0",
    "@gesslar/toolkit": "^5.0.1",
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.4.0",
    "console-ninja": "^1.0.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  }
}
